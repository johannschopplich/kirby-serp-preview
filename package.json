{
  "name": "kirby-serp-preview",
  "type": "module",
  "version": "1.4.1",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "kirbyup serve src/panel/index.ts",
    "build": "kirbyup src/panel/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/panel/**\" --write",
    "test:types": "tsc --noEmit",
    "release": "pnpm run build && bumpp --all --execute \"npx zx scripts/pre-release.mjs\""
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/node": "^26.1.1",
    "@unocss/eslint-plugin": "^66.7.5",
    "bumpp": "^11.1.0",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "kirby-types": "^1.6.0",
    "kirbyup": "^3.4.1",
    "kirbyuse": "^1.3.1",
    "p-throttle": "^8.1.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "unocss": "^66.7.5",
    "vite": "~6.3.7",
    "zx": "^8.8.5"
  }
}
